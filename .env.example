# .env.example

# Application Configuration
ENABLE_FILE_LOGGING=true
LOG_LEVEL='info'
LOG_MAX_SIZE='20m'
LOG_MAX_FILES='14d'
GRAPHQL_ENDPOINT='http://localhost:4000/graphql'
DB_DATA_DIR='src/data'
PUBLIC_CSV_FILE_UPLOAD_LIMIT=50
PUBLIC_VIDEO_BASE_URL='/idle-videos/'
PUBLIC_BASE_URL='http://localhost:5173'

# Capella Configuration
API_BASE_URL='https://cloudapi.cloud.couchbase.com/v4'
ORG_ID='your-org-id'
PROJECT_ID='your-project-id'
CLUSTER_ID='your-cluster-id'
BUCKET_ID='your-bucket-id'
AUTH_TOKEN='your-auth-token'

# Couchbase Connection (Optional - if direct connection needed)
COUCHBASE_URL='couchbases://your-couchbase-url'
COUCHBASE_USERNAME='your-username'
COUCHBASE_PASSWORD='your-password'
COUCHBASE_BUCKET='default'
COUCHBASE_SCOPE='_default'
COUCHBASE_COLLECTION='_default'
COUCHBASE_VECTOR_INDEX='your-vector-index'

# OpenTelemetry Configuration (2025 Standards)
ENABLE_OPENTELEMETRY=true
SERVICE_NAME='Capella Document Search'
SERVICE_VERSION='2.0.2'
DEPLOYMENT_ENVIRONMENT='development'
TRACES_ENDPOINT='your-traces-endpoint'
METRICS_ENDPOINT='your-metrics-endpoint'
LOGS_ENDPOINT='your-logs-endpoint'
METRIC_READER_INTERVAL=60000
CONSOLE_METRIC_READER_INTERVAL=60000
SUMMARY_LOG_INTERVAL=300000

# 2025 Compliance Settings
OTEL_SAMPLING_RATE=0.15          # 15% sampling (2025 standard range: 10-15%)
OTEL_BATCH_SIZE=2048             # 2025 standard batch size
OTEL_QUEUE_SIZE=10000            # 2025 standard queue capacity
OTEL_EXPORT_TIMEOUT=30000        # 30 seconds (2025 standard)
OTEL_NODE_RESOURCE_DETECTORS='env,host,os,serviceinstance'

# Telemetry Circuit Breaker Configuration (SIO-361)
TELEMETRY_CB_FAILURE_THRESHOLD=5        # Failures before circuit opens
TELEMETRY_CB_RECOVERY_TIMEOUT=60000     # Time (ms) before attempting recovery
TELEMETRY_CB_SUCCESS_THRESHOLD=3        # Successes needed to close circuit
TELEMETRY_CB_MONITORING_INTERVAL=10000  # Health check interval (ms)

# Cardinality Guard Configuration (SIO-361)
TELEMETRY_MAX_UNIQUE_LABELS=1000        # Max unique label combinations
TELEMETRY_HASH_BUCKETS=256              # Buckets for overflow hashing
TELEMETRY_CARDINALITY_RESET_INTERVAL=3600000  # Reset interval (ms, 1 hour)

# OpenReplay Configuration
PUBLIC_OPENREPLAY_PROJECT_KEY='your-project-key'
PUBLIC_OPENREPLAY_INGEST_POINT='your-ingest-point'

# Elastic Configuration
PUBLIC_ELASTIC_APM_SERVICE_NAME='Capella Document Search'
PUBLIC_ELASTIC_APM_SERVER_URL='your-apm-server-url'
PUBLIC_ELASTIC_APM_SERVICE_VERSION='2.0.2'
PUBLIC_ELASTIC_APM_ENVIRONMENT='development'
PUBLIC_ELASTIC_APM_DISTRIBUTED_TRACING_ORIGINS='*'

# Azure Configuration
PUBLIC_AZURE_CLIENT_ID='your-client-id'
PUBLIC_AZURE_TENANT_ID='your-tenant-id'
PUBLIC_AZURE_REDIRECT_URI='http://localhost:5173/login'

# RAG Configuration
# RAG_PIPELINE options: 'PINECONE', 'CAPELLA', 'AWS_KNOWLEDGE_BASE'
RAG_PIPELINE='AWS_KNOWLEDGE_BASE'
OPENAI_API_KEY='your-openai-api-key'
PINECONE_API_KEY='your-pinecone-api-key'
PINECONE_INDEX_NAME='your-pinecone-index-name'
PINECONE_NAMESPACE='your-pinecone-namespace'

# AWS Bedrock Configuration
AWS_REGION='eu-central-1'
AWS_ACCESS_KEY_ID='your-access-key'
AWS_SECRET_ACCESS_KEY='your-secret-key'
AWS_BEARER_TOKEN_BEDROCK='your-session-token'
BEDROCK_EMBEDDING_MODEL='amazon.titan-embed-text-v1'
BEDROCK_CHAT_MODEL='eu.anthropic.claude-3-7-sonnet-20250219-v1:0'
BEDROCK_MAX_TOKENS=8000
BEDROCK_MAX_TOOL_RECURSION_DEPTH=4
KNOWLEDGE_BASE_ID='your-knowledge-base-id'

# LangSmith Configuration
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT='https://api.smith.langchain.com'
LANGSMITH_API_KEY='your-langsmith-api-key'
LANGSMITH_PROJECT='your-project-name'

# Chat Timeout Configuration (in milliseconds)
CHAT_REQUEST_TIMEOUT=300000        # 5 minutes - main request timeout
CHAT_FAILSAFE_TIMEOUT=270000       # 4.5 minutes - failsafe to clear thinking state
CHAT_STUCK_CHECK_TIMEOUT=240000    # 4 minutes - threshold for stuck messages
CHAT_PROGRESS_UPDATE_INTERVAL=3000 # 3 seconds - how often to send progress updates

# GrowthBook Feature Flags
PUBLIC_GROWTHBOOK_API_HOST='https://cdn.growthbook.io'
PUBLIC_GROWTHBOOK_CLIENT_KEY='your-client-key'
PUBLIC_GROWTHBOOK_ENCRYPTION_KEY='your-encryption-key'
